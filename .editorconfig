# Editor configuration
# EditorConfig is awesome: https://EditorConfig.org

root = true

[*]
charset = utf-8
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.ts]
indent_size = 2
quote_type = single

[*.html]
indent_size = 2

[*.css]
indent_size = 2
